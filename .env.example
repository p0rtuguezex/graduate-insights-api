# ==== Base de Datos ====
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/graduate_insights
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# ==== CORS ====
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*
CORS_EXPOSED_HEADERS=Authorization,Content-Type,X-Total-Count
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# ==== JWT ====
JWT_SECRET_KEY=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ==== Admin seed (usuario director creado al iniciar) ====
APP_SEED_ADMIN_EMAIL=director@university.edu
APP_SEED_ADMIN_PASSWORD=Director123*

# ==== Resend email (auto-configura email al iniciar si se provee) ====
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_SENDER_EMAIL=noreply@egresadosunu.com
RESEND_SENDER_NAME=EgreSys

# ==== Archivos ====
APP_FILE_UPLOAD_DIR=./uploads/cv
APP_FILE_TMP_DIR=./uploads/tmp

# ==== JVM (solo Docker) ====
JAVA_OPTS=-Xms128m -Xmx256m -XX:+UseG1GC -XX:+UseContainerSupport

# ==== Logging ====
LOGGING_LEVEL_ROOT=INFO
