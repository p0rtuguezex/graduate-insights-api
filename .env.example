# Configuración de Base de Datos
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/graduate_insights
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# Configuración de Correo Electrónico
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_app_password
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true
MAIL_TIMEOUT=10000
MAIL_SSL_TRUST=smtp.gmail.com

# Configuración de CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://tu-dominio.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*
CORS_EXPOSED_HEADERS=Authorization,Content-Type,X-Total-Count
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# Configuración JVM para Docker
JAVA_OPTS=-Xms128m -Xmx256m -XX:+UseG1GC -XX:+UseContainerSupport

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_MAIL=DEBUG

# Configuración JWT
JWT_SECRET_KEY=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
